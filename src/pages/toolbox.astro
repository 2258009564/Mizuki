---
import Icon from "../components/misc/Icon.astro";
import { siteConfig } from "../config";
import { getToolboxItemsByType, getToolboxStats } from "../data/toolbox";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { url } from "../utils/url-utils";

if (!siteConfig.featurePages.toolbox) {
	return Astro.redirect("/404/");
}

const softwareItems = getToolboxItemsByType("software");
const stats = getToolboxStats();

const title = i18n(I18nKey.toolbox);
const subtitle = i18n(I18nKey.toolboxSubtitle);
---

<MainGridLayout title={title} description={subtitle}>
	<script>
		import("../scripts/right-sidebar-layout.js");
	</script>

	<div
		class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32"
	>
		<div class="card-base z-10 px-9 py-6 relative w-full">
			<div class="flex flex-col items-start justify-center mb-8">
				<h1
					class="text-4xl font-bold text-90 mb-2 relative
					before:w-1 before:h-8 before:rounded-md before:bg-(--primary)
					before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4"
				>
					{i18n(I18nKey.toolbox)}
				</h1>
				<p class="text-lg text-60">{i18n(I18nKey.toolboxSubtitle)}</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-1 gap-4 mb-10">
				<div
					class="rounded-lg p-4 border border-indigo-500/25 bg-indigo-500/10 dark:bg-indigo-900/30"
				>
					<div
						class="text-2xl font-bold text-indigo-600 dark:text-indigo-300"
					>
						{stats.total}
					</div>
					<div
						class="text-sm text-indigo-600/70 dark:text-indigo-300/80"
					>
						{i18n(I18nKey.toolboxTotal)}
					</div>
				</div>
			</div>
			<p class="text-sm text-60 mb-6">
                本页面仅供测试使用，涵盖的任何内容均不代表真实情况，敬请期待。
			</p>

			<div class="space-y-10">
				<section>
					<h2
						class="text-2xl font-bold text-90 mb-4 relative
						before:w-1 before:h-6 before:rounded-md before:bg-(--primary)
						before:absolute before:top-1/2 before:-translate-y-1/2 before:-left-4"
					>
						{i18n(I18nKey.toolboxSoftware)}
						<span class="text-lg font-normal text-60 ml-2"
							>({softwareItems.length})</span
						>
					</h2>
					<div
						class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5"
					>
						{
							softwareItems.map((item, index) => (
								<article
									class="tool-card group rounded-xl border border-(--line-divider) bg-(--card-bg) p-5"
									style={`animation-delay: ${index * 70}ms`}
								>
									<div class="flex items-start justify-between gap-3 mb-3">
										<div class="flex items-center gap-3 min-w-0">
											<div class="w-11 h-11 shrink-0 rounded-lg bg-(--btn-regular-bg) flex items-center justify-center text-(--primary)">
												<Icon
													icon={item.icon}
													class="text-xl"
													fallback={item.name.charAt(
														0,
													)}
													loading="eager"
												/>
											</div>
											<h3 class="text-lg font-semibold text-90 truncate">
												{item.name}
											</h3>
										</div>
										<Icon
											icon="material-symbols:extension"
											class="text-lg text-(--primary) opacity-0 group-hover:opacity-100 transition-opacity"
											loading="eager"
										/>
									</div>
									<p class="text-sm text-60 line-clamp-2 min-h-10 mb-3">
										{item.description}
									</p>
									<div class="flex flex-wrap gap-2 mb-3">
										{item.tags.map((tag) => (
											<span class="px-2 py-1 rounded-md text-xs bg-(--primary)/10 text-(--primary)">
												{tag}
											</span>
										))}
									</div>
									<div class="pt-3 border-t border-(--line-divider) border-dashed flex items-center justify-between gap-3 mb-3">
										<span class="text-xs text-50 truncate">
											{item.platform}
										</span>
										<span class="text-sm font-medium text-(--primary)">
											配置 + 插件
										</span>
									</div>

									<div class="grid grid-cols-2 gap-2">
										<a
											href={url(`/toolbox/${item.id}/`)}
											class="text-center text-sm font-medium px-3 py-2 rounded-lg bg-(--primary) text-white hover:opacity-90 transition-opacity"
										>
											查看插件页
										</a>
										<a
											href={item.url}
											target="_blank"
											rel="noopener noreferrer"
											class="text-center text-sm font-medium px-3 py-2 rounded-lg border border-(--line-divider) text-80 hover:text-(--primary) hover:border-(--primary)/50 transition-colors"
										>
											{i18n(I18nKey.toolboxVisit)}
										</a>
									</div>
								</article>
							))
						}
					</div>
				</section>
			</div>
		</div>
	</div>
</MainGridLayout>

<style>
	.tool-card {
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease,
			border-color 0.25s ease;
		animation: fadeInUp 0.55s ease forwards;
		opacity: 0;
	}

	.tool-card:hover {
		transform: translateY(-3px);
		border-color: color-mix(
			in srgb,
			var(--primary) 45%,
			var(--line-divider)
		);
		box-shadow: 0 10px 24px rgb(0 0 0 / 8%);
	}

	:root.dark .tool-card:hover {
		box-shadow: 0 10px 24px rgb(255 255 255 / 6%);
	}

	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
